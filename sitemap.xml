---
layout: null
permalink: /sitemap.xml
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% assign pages = site.pages | where_exp: "item", "item.sitemap != false" %}
{% for page in pages %}
{% unless page.url contains "/assets/" %}
  <url>
    <loc>{{ page.url | absolute_url }}</loc>
    <lastmod>{{ page.last_modified_at | default: site.time | date: "%Y-%m-%d" }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>{% if page.url == "/" %}1.0{% else %}0.7{% endif %}</priority>
  </url>
{% endunless %}
{% endfor %}
</urlset>

